<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <base-config cleartextTrafficSheetingPermitted="false">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>
    <domain-config cleartextTrafficSheetingPermitted="false">
        <domain includeSubdomains="true">api.nextdns.io</domain>
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </domain-config>
</network-security-config>
